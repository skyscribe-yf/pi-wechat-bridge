# pi-wechat-bridge 配置

# ===== 企业微信应用配置 =====
# 在企业微信管理后台 https://work.weixin.qq.com/wework_admin/frame#apps 创建自建应用后获取
# 企业的 CorpID（在我的企业 → 企业信息 → 企业ID）
WXWORK_CORP_ID=

# 自建应用的 AgentId
WXWORK_AGENT_ID=

# 自建应用的 Secret
WXWORK_SECRET=

# 接收消息的 Token（在应用 → 接收消息 → 设置API接收 时设置）
WXWORK_TOKEN=

# 接收消息的 EncodingAESKey（同上，点随机获取）
WXWORK_ENCODING_AES_KEY=

# ===== pi Agent 配置 =====
# pi 的工作目录（pi 会在该目录下操作文件）
PI_CWD=/home/skyscribe/srcs/token-stats

# 可选：指定 provider 和 model（不设置则用 pi 默认配置）
# PI_PROVIDER=anthropic
# PI_MODEL=claude-sonnet-4

# 思考等级: low, medium, high
PI_THINKING=medium

# 允许的工具列表
PI_TOOLS=read,bash,edit,write,grep,find,ls

# 是否关闭会话持久化（默认 false，同一用户多轮对话共享上下文）
# PI_NO_SESSION=true

# 追加 system prompt（引导 pi 输出格式，如 diff 友好格式）
# PI_APPEND_SYSTEM_PROMPT=当修改代码时，请用 diff 格式展示变更

# 空闲回收阈值（毫秒，默认 30 分钟）
# PI_SESSION_IDLE_MS=1800000

# pi 可执行文件绝对路径（systemd 环境下通常需要设置）
# PI_BIN_PATH=/home/skyscribe/.nvm/versions/node/v24.15.0/bin/pi

# 以下设为 true 可减少启动开销，但会失去扩展/技能/上下文功能
# PI_NO_EXTENSIONS=true
# PI_NO_SKILLS=true
# PI_NO_CONTEXT_FILES=true

# ===== 服务器配置 =====
# 桥接服务器监听端口
BRIDGE_PORT=3100

# 允许的微信用户列表（企业微信UserID，逗号分隔，留空则允许所有人）
# ALLOWED_USERS=user1,user2

# 管理员用户ID（用于 tunnel URL 通知，默认取 ALLOWED_USERS 的第一个）
# ADMIN_USER=user1
